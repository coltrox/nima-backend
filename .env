# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Credenciais do Supabase (Pegue no painel do Supabase > Project Settings > API)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-anon-public-ou-service-role

# Configuração do Banco de Dados (Sequelize)
# Se estiver usando o banco do Supabase via PostgreSQL:
DB_HOST=aws-0-sa-east-1.pooler.supabase.com
DB_USER=postgres.seu-usuario
DB_PASS=sua-senha-do-banco
DB_NAME=postgres
DB_PORT=5432
DB_DIALECT=postgres

# Integração com n8n (A URL do Webhook que você criou no n8n)
N8N_WEBHOOK_URL=https://n8n.seu-dominio.com/webhook/identificador-do-match

# JWT Secret (Caso use alguma validação extra local)
JWT_SECRET=coloque_uma_string_aleatoria_e_longa_aqui